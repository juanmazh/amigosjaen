# Puerto del servidor
PORT=5000

# URL de conexión a la base de datos
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/basedatos

# Variables alternativas para desarrollo local
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=amigosjaen

# JWT - usa una clave larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET=tu_clave_secreta_muy_larga_y_aleatoria_aqui

# URL del frontend
FRONTEND_URL=http://localhost:5173

# Entorno
NODE_ENV=development
